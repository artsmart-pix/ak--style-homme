# Environnement local — ne pas committer
.env
# Install WordPress runtime ignorée…
wordpress/*
!wordpress/wp-content/
wordpress/wp-content/*
!wordpress/wp-content/themes/
wordpress/wp-content/themes/*
# …SAUF les child themes (travail client versionné — core/parent/plugins restent ignorés)
!wordpress/wp-content/themes/*-child/
library/themes/*.zip
library/plugins/*.zip
*.log

# Artefacts de déploiement (zip du site + dump DB avec données clients) — locaux uniquement
deploy/

# Kit de template Elementor (référence visuelle, non livrable)
Laste - Real Estate & Property Elementor Template Kit/
Medco - Medical Clinic & Hospital Elementor Template Kit/

# Plugin premium de référence (formulaire COD/arabe, non livrable) — base des améliorations
woo-jude-form-premium.1.0.7/

# BMAD — config personnelle uniquement (le reste est versionné)
**/config.user.toml

# Exports/téléchargements depuis la prod Hostinger (données clients/PII, volumineux) — jamais versionnés
contenu-gestionnaire-fichier-hostinger/
