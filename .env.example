# Modèle d'environnement — copier vers .env puis remplir.
#   cp .env.example .env
# Le vrai .env n'est PAS versionné (cf .gitignore). Choisis des valeurs
# propres à CHAQUE projet — ne réutilise pas les mots de passe d'un autre site.

# ─── Isolation du projet (OBLIGATOIRE) ─────────────
# ⚠️ UNIQUE par clone. Les conteneurs sont nommés wp_app_${PROJECT_SLUG},
# wp_db_${PROJECT_SLUG}, wp_cli_${PROJECT_SLUG}, wp_pma_${PROJECT_SLUG}.
# Deux projets avec le même slug pilotent les MÊMES conteneurs → un projet peut
# installer par erreur dans un autre. Personnalise-le AVANT le 1er `docker compose up`,
# et vérifie qu'il n'est pas déjà pris : `docker ps -a --format '{{.Names}}'`.
PROJECT_SLUG=mon-projet           # ex. miellerie, pantalon-femme — [a-z0-9-]
COMPOSE_PROJECT_NAME=mon-projet   # idem : isole réseaux & volumes Docker

# ─── Base de données ───────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_db

# ─── Ports (hôte) — UNIQUES par projet ─────────────
# Si un autre clone tourne déjà sur 8090/8091, choisis d'autres ports libres
# (8092/8093, 8094/8095…) sinon collision au démarrage.
WP_PORT=8090
PMA_PORT=8091

# ─── WordPress admin (utilisé par scripts/setup.sh) ─
WP_URL=http://localhost:8090
WP_TITLE="Ma Boutique"
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me_admin
WP_ADMIN_EMAIL=admin@example.com
